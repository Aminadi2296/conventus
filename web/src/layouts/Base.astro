---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Schedule team meetings without the back-and-forth.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Conventus</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --ink: #0E0E10;
        --ink-soft: #1C1C20;
        --ink-muted: #3A3A42;
        --ink-faint: #6B6B75;
        --cream: #F5F0E8;
        --cream-soft: #FAF7F2;
        --amber: #E8A020;
        --amber-light: #F5C842;
        --amber-dark: #B87818;
        --amber-pale: #FDF3DC;
        --border: rgba(14,14,16,0.1);
        --border-strong: rgba(14,14,16,0.2);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        background: var(--cream-soft);
        color: var(--ink);
        font-family: 'DM Sans', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      body {
        min-height: 100dvh;
      }

      h1, h2, h3 {
        font-family: 'DM Serif Display', Georgia, serif;
        font-weight: 400;
        line-height: 1.15;
        letter-spacing: -0.02em;
      }

      ::selection {
        background: var(--amber-light);
        color: var(--ink);
      }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
