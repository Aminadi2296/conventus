# Astro loads env files by mode (see https://docs.astro.build/en/guides/environment-variables/)
#
# Local dev (astro dev):  .env.development  → http://localhost:3000
# Production (astro build): .env.production → https://conventus-9q9k.onrender.com
#
# Optional overrides (gitignored): .env.local or .env.[mode].local

PUBLIC_API_URL=http://localhost:3000
